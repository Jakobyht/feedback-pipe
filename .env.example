# Copy to .env and edit. `npm run pipe` loads this automatically.

# Required: the inbound key callers must send (any secret string).
PIPE_API_KEY=change-me

# Required: the repository the agent works on (absolute path).
PIPE_REPO=/absolute/path/to/repo

# Optional: defaults to Claude Code in headless mode.
# PIPE_AGENT_COMMAND=claude -p "$(cat "$APE_TASK_PROMPT_FILE")" --permission-mode acceptEdits

# Optional: listen port (default 8181), bind address, and a label for tasks.
# PIPE_PORT=8181
# PIPE_HOST=127.0.0.1
# PIPE_WORKSPACE=default
