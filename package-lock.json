{
  "name": "feedback-pipe",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "feedback-pipe",
      "version": "0.1.0",
      "workspaces": [
        "packages/*"
      ],
      "engines": {
        "node": ">=20"
      }
    },
    "../../shared": {
      "extraneous": true
    },
    "node_modules/@ape/pipe": {
      "resolved": "packages/pipe",
      "link": true
    },
    "node_modules/@ape/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "packages/brain": {
      "name": "@ape/brain",
      "version": "0.1.0",
      "extraneous": true,
      "dependencies": {
        "@ape/shared": "0.1.0",
        "ws": "^8.18.0"
      },
      "bin": {
        "ape-brain": "src/server.js"
      }
    },
    "packages/pipe": {
      "name": "@ape/pipe",
      "version": "0.1.0",
      "dependencies": {
        "@ape/shared": "*"
      },
      "bin": {
        "feedback-pipe": "src/server.js"
      }
    },
    "packages/runner": {
      "name": "autonomous-agent",
      "version": "0.1.0",
      "extraneous": true,
      "dependencies": {
        "@ape/shared": "0.1.0",
        "ws": "^8.18.0"
      },
      "bin": {
        "autonomous-agent": "src/cli.js"
      }
    },
    "packages/shared": {
      "name": "@ape/shared",
      "version": "0.1.0"
    }
  }
}
